NODE_ENV=development
PORT=3000

# ─── Firebase ────────────────────────────────────────────
# Local/OSS: solo PROJECT_ID, el emulador no necesita credenciales
# Dev/QA/Prod: agregar CLIENT_EMAIL + PRIVATE_KEY (vienen de Infisical)
FIREBASE_PROJECT_ID=demo-carpil
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Stripe ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# ─── Varios ──────────────────────────────────────────────
CHAT_SECRET=dev_secret
