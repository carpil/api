{
  "name": "carpil-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --require tsconfig-paths/register --respawn src/index.ts",
    "start": "node -r module-alias/register build/index.js",
    "lint": "ts-standard",
    "tsc": "tsc",
    "build": "tsc && cp -r src/config/*.json build/config/",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/express": "5.0.0",
    "ts-node-dev": "2.0.0",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.7.3"
  },
  "dependencies": {
    "express": "4.21.2",
    "firebase-admin": "13.1.0",
    "module-alias": "2.2.3",
    "ts-standard": "12.0.2",
    "zod": "3.24.2"
  },
  "_moduleAliases": {
    "@models": "build/models",
    "@middlewares": "build/middlewares",
    "@utils": "build/utils"
  },
  "eslintConfig": {
    "parserOptions": {
      "project": "./tsconfig.json"
    },
    "extends": [
      "./node_modules/ts-standard/eslintrc.json"
    ]
